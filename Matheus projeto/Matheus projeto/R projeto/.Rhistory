install.packages('deflateBR')
library(dplyr)
library(lubridate)
library(urca)      # Testes de Raiz Unitária
library(forecast)  # Modelos ARIMA e Previsão
# 1. CARGA E LIMPEZA (Garantindo que o preço seja numérico)
nome_arq <- "cepea-consulta-20260320091531.csv"
dados_brutos <- read.csv2(nome_arq, skip = 4, header = FALSE)
df_limpo <- dados_brutos %>%
rename(mes_ano = V1, preco = V2) %>%
mutate(
data = my(mes_ano),
preco = as.numeric(preco) # Garante que o log() funcione
) %>%
filter(!is.na(data), !is.na(preco))
# 2. CRIAR SÉRIE TEMPORAL E LOG (Usando o df_limpo correto)
# Note: Usamos df_limpo$preco agora
log_milho <- ts(log(df_limpo$preco), frequency = 12,
start = c(year(min(df_limpo$data)), month(min(df_limpo$data))))
# 3. TESTES DE RAIZ UNITÁRIA (Dickey-Fuller - Os 3 modelos que você usa)
# Modelo 1: Sem intercepto e sem tendência
dickey1 <- ur.df(log_milho, type = "none", lags = 0)
summary(dickey1)
# Modelo 2: Com intercepto (drift)
dickey2 <- ur.df(log_milho, type = "drift", lags = 0)
summary(dickey2)
# Modelo 3: Com intercepto e tendência
dickey3 <- ur.df(log_milho, type = "trend", lags = 0)
summary(dickey3)
# 4. IDENTIFICAÇÃO (FAC e FAPC)
par(mfrow=c(1,2))
acf(log_milho, lag.max = 36, main="FAC Log Milho", col="red")
pacf(log_milho, lag.max = 36, main="FAPC Log Milho", col="red")
par(mfrow=c(1,1))
# 5. TESTES DE AUTOCORRELAÇÃO (Ljung-Box)
Box.test(log_milho, lag = 1, type = "Ljung-Box")
Box.test(log_milho, lag = 12, type = "Ljung-Box")
# 6. ESTIMAÇÃO DO SEU MODELO ESPECÍFICO ARIMA(1,1,3)
Arima113 <- Arima(log_milho, order = c(1, 1, 3), method = "ML")
print("--- Coeficientes Arima 113 ---")
print(Arima113$coef)
# Diagnóstico dos resíduos (O gráfico que você pediu)
tsdiag(Arima113)
# 7. ACURÁCIA DO MODELO
accuracy(Arima113)
# 8. Gerar a previsão para os próximos 6 meses (h = 6)
# Usamos a função forecast para facilitar a plotagem gráfica
previsao_grafico <- forecast(Arima113, h = 6)
# 9. Plotar o gráfico da série em LOG (Previsão do modelo)
plot(previsao_grafico,
main = "Previsão do Preço do Milho - Modelo ARIMA(1,1,3)",
xlab = "Anos",
ylab = "Preço (em Log)",
col = "black",
fcol = "blue", # Cor da linha da previsão
shadecols = "lightblue") # Cor da área de incerteza
library(dplyr)
library(ggplot2)
library(lubridate)
library(tidyr)
library(deflateBR)
# 1. CARGA E LIMPEZA DO SPOT (CEPEA)
# Usando o arquivo atualizado que você forneceu
df_spot <- read.csv2("cepea-consulta-20260325022533.csv", skip = 4, header = FALSE) %>%
rename(mes_ano = V1, preco_nominal = V2) %>%
mutate(data = my(mes_ano),
preco_nominal = as.numeric(preco_nominal)) %>%
filter(!is.na(data)) %>%
arrange(data)
# 2. DEFLACIONAMENTO (Preço Real)
# Deflacionando a série Spot completa usando IPCA com data base em Dezembro/2024
# conforme a lógica do seu código de Dívida Pública.
df_spot <- df_spot %>%
mutate(preco_real = deflate(preco_nominal,
nominal_dates = data,
real_date = '2024-12',
index = 'ipca'))
# 3. CARGA E LIMPEZA DO FUTURO
df_futuro <- read.csv("Dados Históricos - Milho Chicago Futuros.csv", sep=",", dec=",") %>%
mutate(data = dmy(Data),
preco_futuro_nominal = as.numeric(Último)) %>%
filter(!is.na(data)) %>%
arrange(data) %>%
select(data, preco_futuro_nominal)
# 4. UNIÃO E COMPARAÇÃO
# Unimos para ter certeza que comparamos Nominal vs Real no mesmo período
df_comparativo <- df_spot %>%
inner_join(df_futuro, by = "data")
# 5. PREPARAÇÃO PARA O GRÁFICO (NOMINAL VS REAL)
# Vamos focar na visualização do Spot para ver o efeito da inflação
df_plot_inflacao <- df_comparativo %>%
select(data, preco_nominal, preco_real) %>%
pivot_longer(cols = c(preco_nominal, preco_real),
names_to = "Tipo", values_to = "Valor")
# 6. GRÁFICO: NOMINAL VS REAL (SPOT CEPEA)
ggplot(df_plot_inflacao, aes(x = data, y = Valor, color = Tipo)) +
geom_line(linewidth = 1) +
scale_color_manual(values = c("preco_nominal" = "red", "preco_real" = "blue"),
labels = c("Preço Nominal (R$ da época)", "Preço Real (Base 12/2024)")) +
scale_x_date(date_labels = "%Y", date_breaks = "2 years") +
labs(title = "Milho Cepea: Impacto da Inflação (IPCA)",
subtitle = "Comparação entre Preços Nominais e Preços Deflacionados",
x = "Ano", y = "R$ por Saca", color = "Legenda") +
theme_minimal()
# 7. GRÁFICO: SPOT REAL VS FUTURO (A análise de Hedge correta)
# O contrato futuro já embuti expectativa inflacionária, mas comparar
# ambos em termos reais limpa o 'ruído' monetário.
ggplot(df_comparativo, aes(x = data)) +
geom_line(aes(y = preco_real, color = "Spot Real (Cepea)"), linewidth = 0.8) +
geom_line(aes(y = preco_futuro_nominal, color = "Futuro (Chicago/B3)"), linewidth = 0.8, linetype = "dashed") +
scale_color_manual(values = c("Spot Real (Cepea)" = "darkgreen", "Futuro (Chicago/B3)" = "darkblue")) +
labs(title = "Hedge de Milho: Spot Real vs. Futuro",
subtitle = "Preços deflacionados facilitam a visualização do risco de base",
x = "Período", y = "R$/Saca", color = "Série") +
theme_minimal()
