H_DIAS <- 15   # horizonte de previsão
# Função que ajusta ARIMA e retorna df formatado
arima_commodity <- function(df_comm, nome) {
serie <- ts(log(df_comm$SPOT))
fit  <- tryCatch(
Arima(serie, order = c(1, 1, 3)),
error = function(e) {
warning(paste("ARIMA falhou para", nome, ":", e$message))
return(NULL)
}
)
if (is.null(fit)) return(NULL)
prev <- forecast(fit, h = H_DIAS, level = CONFIANCA_IC * 100)
n    <- length(serie)
# Histórico
hist_df <- data.frame(
id        = seq_len(n),
Preco     = exp(as.numeric(serie)),
Lower     = NA_real_,
Upper     = NA_real_,
Tipo      = "Histórico",
Commodity = nome
)
# Projeção
proj_df <- data.frame(
id        = seq(n + 1, n + H_DIAS),
Preco     = exp(as.numeric(prev$mean)),
Lower     = exp(as.numeric(prev$lower)),
Upper     = exp(as.numeric(prev$upper)),
Tipo      = "Previsão",
Commodity = nome
)
bind_rows(hist_df, proj_df)
}
# Aplica para cada commodity disponível
df_arima <- df_all %>%
group_by(Commodity) %>%
group_map(~ arima_commodity(.x, as.character(.y[[1]])), .keep = TRUE) %>%
bind_rows() %>%
mutate(Commodity = factor(Commodity, levels = levels(df_all$Commodity)))
# Gráfico
df_arima %>%
ggplot(aes(x = id, y = Preco)) +
geom_ribbon(
data = filter(df_arima, Tipo == "Previsão"),
aes(ymin = Lower, ymax = Upper, fill = Commodity),
alpha = 0.2, show.legend = FALSE
) +
geom_line(aes(color = Tipo, linetype = Tipo), linewidth = 0.9) +
scale_color_manual(values   = c("Histórico" = "gray30", "Previsão" = "#e74c3c")) +
scale_linetype_manual(values = c("Histórico" = "solid",  "Previsão" = "dashed")) +
scale_fill_manual(values = CORES) +
scale_y_continuous(labels = label_number(big.mark = ".", decimal.mark = ",")) +
facet_wrap(~ Commodity, scales = "free_y", ncol = 2) +
labs(
title    = glue::glue("Previsão ARIMA(1,1,3): SPOT por Commodity — {H_DIAS} dias úteis"),
subtitle = "Faixa sombreada = intervalo de confiança de 95%",
x        = "Dias decorridos",
y        = "R$ / Saca (ou R$ / @)",
color    = NULL,
linetype = NULL
) +
theme_minimal(base_size = 12) +
theme(legend.position = "top", strip.text = element_text(face = "bold"))
# Tabela com os valores projetados
df_arima %>%
filter(Tipo == "Previsão") %>%
group_by(Commodity) %>%
summarise(
`Dias previstos`     = n(),
`Previsão inicial`   = first(Preco),
`Previsão final`     = last(Preco),
`Variação (%)`       = (last(Preco) / first(Preco) - 1) * 100,
`IC inf. (último)`   = last(Lower),
`IC sup. (último)`   = last(Upper),
.groups              = "drop"
) %>%
kable(
digits      = 2,
caption     = glue::glue("Previsão ARIMA para os próximos {H_DIAS} dias úteis"),
format.args = list(big.mark = ".", decimal.mark = ",")
) %>%
kable_styling(
bootstrap_options = c("striped", "hover", "condensed"),
full_width = FALSE
)
