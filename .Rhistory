)
df_all %>%
filter(!is.na(Retorno_SPOT), !is.na(Retorno_FUT)) %>%
group_by(Commodity) %>%
summarise(
# Razão ótima de hedge (OHR) = Cov(ΔSpot, ΔFUT) / Var(ΔFUT)
OHR                   = cov(Retorno_SPOT, Retorno_FUT, use = "complete.obs") /
var(Retorno_FUT, na.rm = TRUE),
# R² da regressão (efetividade)
`Efetividade (%)`     = summary(
lm(Retorno_SPOT ~ Retorno_FUT)
)$r.squared * 100,
`Corr. SPOT×FUT`      = cor(Retorno_SPOT, Retorno_FUT, use = "complete.obs"),
`Var. SPOT`           = var(Retorno_SPOT, na.rm = TRUE),
`Var. FUT`            = var(Retorno_FUT, na.rm = TRUE),
.groups               = "drop"
) %>%
kable(
digits  = 4,
caption = "Razão ótima de hedge (OHR) e efetividade por commodity"
) %>%
kable_styling(
bootstrap_options = c("striped", "hover", "condensed"),
full_width = FALSE
) %>%
footnote(
general = "OHR > 1: hedge exige mais contratos que o volume físico. Efetividade próxima de 100%: hedge quase perfeito.",
general_title = "Nota:"
)
