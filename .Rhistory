# ===========================================================
# PACOTES
# ===========================================================
library(dplyr)
library(ggplot2)
library(lubridate)
library(tidyr)
library(knitr)
library(kableExtra)
library(scales)
library(patchwork)
library(forecast)   # ARIMA
options(scipen = 999999)
# ===========================================================
# PARÂMETROS GLOBAIS
# ===========================================================
SACAS_CONTRATO <- 450          # sacas por contrato padrão BM&F
CONFIANCA_IC   <- 0.95         # nível de confiança para o IC
# Paleta de cores por commodity
CORES <- c(
"Soja"      = "#e74c3c",
"Milho"     = "#f39c12",
"Café"      = "#8e44ad",
"Boi Gordo" = "#2980b9"
)
# ===========================================================
# FUNÇÃO GENÉRICA DE LEITURA E CÁLCULO
# ===========================================================
ler_commodity <- function(caminho, nome_commodity) {
# --- 0. Verificação de existência do arquivo ---
if (!file.exists(caminho)) {
warning(paste("Arquivo não encontrado:", caminho))
return(NULL)
}
# --- 1. Leitura bruta com tratamento de erro ---
df_raw <- tryCatch(
read.csv(
caminho,
skip             = 1,
header           = TRUE,
sep              = ",",
dec              = ".",
stringsAsFactors = FALSE,
fileEncoding     = "UTF-8"
),
error = function(e) {
warning(paste("Erro ao ler", caminho, ":", e$message))
return(NULL)
}
)
if (is.null(df_raw)) return(NULL)
# Garante que o df tem colunas suficientes
if (ncol(df_raw) < 12) {
warning(paste("Arquivo", caminho, "tem menos colunas que o esperado."))
return(NULL)
}
# Padroniza nomes de colunas
colnames(df_raw)[1:12] <- c(
"Data", "SPOT", "FUT_Invest", "Base_orig",
"ENTRAGA_V_orig", "SAIDA_V_orig", "RESULTADO_V_orig", "R450V_orig",
"ENTRAGA_C_orig", "SAIDA_C_orig", "RESULTADO_C_orig", "R450C_orig"
)
# --- 2. Limpeza: mantém apenas linhas com data no formato DD/MM/AAAA ---
df <- df_raw %>%
filter(
!is.na(Data),
Data != "",
grepl("^\\d{2}/\\d{2}/\\d{4}$", trimws(Data))
) %>%
mutate(
Data       = dmy(trimws(Data)),
SPOT       = as.numeric(gsub(",", ".", as.character(SPOT))),
FUT_Invest = as.numeric(gsub(",", ".", as.character(FUT_Invest)))
) %>%
filter(!is.na(SPOT), !is.na(FUT_Invest)) %>%
arrange(Data)
if (nrow(df) == 0) {
warning(paste("Nenhuma linha válida encontrada em:", caminho))
return(NULL)
}
# --- 3. Recálculo das colunas derivadas ---
df <- df %>%
mutate(
# ── Base (risco de base) ──
Base = SPOT - FUT_Invest,
# ── Hedge de Venda (Short Hedge — produtor/exportador) ──
# Lucra quando o preço futuro cai (posição vendida no futuro)
ENTRAGA_V   = lag(FUT_Invest, 1),
SAIDA_V     = FUT_Invest,
RESULTADO_V = ENTRAGA_V - SAIDA_V,
R450_V      = RESULTADO_V * SACAS_CONTRATO,
R450_V_acum = cumsum(replace_na(R450_V, 0)),
# ── Hedge de Compra (Long Hedge — indústria/importador) ──
# Lucra quando o preço futuro sobe (posição comprada no futuro)
ENTRAGA_C   = lag(FUT_Invest, 1),
SAIDA_C     = FUT_Invest,
RESULTADO_C = SAIDA_C - ENTRAGA_C,
R450_C      = RESULTADO_C * SACAS_CONTRATO,
R450_C_acum = cumsum(replace_na(R450_C, 0)),
# ── Retornos logarítmicos (úteis para ARIMA e análise de risco) ──
Retorno_SPOT = c(NA, diff(log(SPOT))),
Retorno_FUT  = c(NA, diff(log(FUT_Invest))),
Commodity = nome_commodity
)
return(df)
}
# ===========================================================
# CARGA DOS 4 ARQUIVOS
# ===========================================================
df_soja  <- ler_commodity("Dados_soja - Dados.csv",       "Soja")
df_milho <- ler_commodity("Dados_Milho - Dados.csv",      "Milho")
df_cafe  <- ler_commodity("Dados Café - Café (1).csv",    "Café")
df_boi   <- ler_commodity("Dados_boi - boi (1).csv",      "Boi Gordo")
# Remove commodities que não carregaram e empilha
lista_valida <- Filter(Negate(is.null), list(df_soja, df_milho, df_cafe, df_boi))
if (length(lista_valida) == 0) stop("Nenhum arquivo de commodity foi carregado com sucesso.")
df_all <- bind_rows(lista_valida) %>%
mutate(Commodity = factor(Commodity, levels = c("Soja", "Milho", "Café", "Boi Gordo")))
df_all %>%
group_by(Commodity) %>%
slice_head(n = 5) %>%
select(Commodity, Data, SPOT, FUT_Invest, Base, RESULTADO_V, R450_V, RESULTADO_C, R450_C) %>%
kable(
digits    = 2,
caption   = "Primeiras observações por commodity (colunas recalculadas)",
col.names = c("Commodity", "Data", "SPOT", "FUT Invest", "Base",
"Res. Venda", "R$ Venda", "Res. Compra", "R$ Compra"),
format.args = list(big.mark = ".", decimal.mark = ",")
) %>%
kable_styling(
bootstrap_options = c("striped", "hover", "condensed"),
full_width = FALSE
) %>%
collapse_rows(columns = 1, valign = "top")
df_all %>%
select(Commodity, Data, SPOT, FUT_Invest) %>%
pivot_longer(
cols      = c(SPOT, FUT_Invest),
names_to  = "Serie",
values_to = "Preco"
) %>%
mutate(
Serie = case_match(Serie,
"SPOT"       ~ "SPOT (CEPEA)",
"FUT_Invest" ~ "FUT Invest"
)
) %>%
ggplot(aes(x = Data, y = Preco, color = Serie)) +
