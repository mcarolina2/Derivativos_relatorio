SPOT       = as.numeric(gsub(",", ".", as.character(SPOT))),
FUT_Invest = as.numeric(gsub(",", ".", as.character(FUT_Invest)))
) %>%
filter(!is.na(SPOT), !is.na(FUT_Invest)) %>%
arrange(Data)
if (nrow(df) == 0) {
warning(paste("Nenhuma linha válida encontrada em:", caminho))
return(NULL)
}
# --- 3. Recálculo das colunas derivadas ---
df <- df %>%
mutate(
# ── Base (risco de base) ──
Base = SPOT - FUT_Invest,
# ── Hedge de Venda (Short Hedge — produtor/exportador) ──
# Lucra quando o preço futuro cai (posição vendida no futuro)
ENTRAGA_V   = lag(FUT_Invest, 1),
SAIDA_V     = FUT_Invest,
RESULTADO_V = ENTRAGA_V - SAIDA_V,
R450_V      = RESULTADO_V * SACAS_CONTRATO,
R450_V_acum = cumsum(replace_na(R450_V, 0)),
# ── Hedge de Compra (Long Hedge — indústria/importador) ──
# Lucra quando o preço futuro sobe (posição comprada no futuro)
ENTRAGA_C   = lag(FUT_Invest, 1),
SAIDA_C     = FUT_Invest,
RESULTADO_C = SAIDA_C - ENTRAGA_C,
R450_C      = RESULTADO_C * SACAS_CONTRATO,
R450_C_acum = cumsum(replace_na(R450_C, 0)),
# ── Retornos logarítmicos (úteis para ARIMA e análise de risco) ──
Retorno_SPOT = c(NA, diff(log(SPOT))),
Retorno_FUT  = c(NA, diff(log(FUT_Invest))),
Commodity = nome_commodity
)
return(df)
}
